# Groq API Key for agentic reasoning
GROQ_API_KEY=your_groq_key_here

# API Configuration
API_BASE_URL=http://localhost:8000
API_KEY=admin_secret_key_here

# Database Configuration (Defaults to local SQLite)
# For production, use a PostgreSQL URL:
# DATABASE_URL=postgresql://user:password@localhost:5432/stock_forecast
DATABASE_URL=sqlite:///./stock_forecast.db

# Model Configuration
GROQ_MODEL=openai/gpt-oss-20b
