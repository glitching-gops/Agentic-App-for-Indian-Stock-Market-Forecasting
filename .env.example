# Groq API Key for agentic reasoning
GROQ_API_KEY=your_groq_key_here

# API Configuration
API_BASE_URL=http://localhost:8000
ADMIN_API_KEY=admin_secret_key_here

# Database Configuration (Defaults to local SQLite)
# For production, use a PostgreSQL URL:
# DATABASE_URL=postgresql://user:password@localhost:5432/stock_forecast
DATABASE_URL=sqlite:///./stock_forecast.db

# Model Configuration
GROQ_MODEL=openai/gpt-oss-20b

# GitHub Personal Access Token
# Required on Render to download model files from model-store branch
# Create at: github.com/Settings → Developer settings → Personal access tokens → Fine-grained
# Required permissions: Contents → Read-only on Agentic-App-for-Indian-Stock-Market-Forecasting repo
GITHUB_TOKEN=your_github_token_here

# Set to 1 on memory-constrained hosts (Render free tier = 512MB) to prevent
# TimesFM (800MB weights) from OOM-killing the server during the daily pipeline run.
# Leave unset or 0 for local development and GPU servers.
DISABLE_TIMESFM=0